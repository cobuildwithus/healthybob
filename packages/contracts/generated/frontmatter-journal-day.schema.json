{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "@healthybob/contracts/frontmatter-journal-day.schema.json",
  "title": "Healthy Bob Journal Day Frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "docType",
    "dayKey",
    "eventIds",
    "sampleStreams"
  ],
  "properties": {
    "schemaVersion": {
      "const": "hb.frontmatter.journal-day.v1"
    },
    "docType": {
      "const": "journal_day"
    },
    "dayKey": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "eventIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^evt_[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "uniqueItems": true
    },
    "sampleStreams": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "heart_rate",
          "hrv",
          "steps",
          "sleep_stage",
          "respiratory_rate",
          "temperature",
          "glucose"
        ]
      },
      "uniqueItems": true
    }
  }
}
