{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "@healthybob/contracts/vault-metadata.schema.json",
  "title": "Healthy Bob Vault Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "vaultId",
    "createdAt",
    "title",
    "timezone",
    "idPolicy",
    "paths",
    "shards"
  ],
  "properties": {
    "schemaVersion": {
      "const": "hb.vault.v1"
    },
    "vaultId": {
      "type": "string",
      "pattern": "^vault_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "timezone": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64
    },
    "idPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "prefixes"
      ],
      "properties": {
        "format": {
          "const": "prefix_ulid"
        },
        "prefixes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allergy",
            "assessment",
            "audit",
            "condition",
            "document",
            "event",
            "experiment",
            "family",
            "goal",
            "meal",
            "pack",
            "profileSnapshot",
            "provider",
            "regimen",
            "sample",
            "transform",
            "variant",
            "vault"
          ],
          "properties": {
            "allergy": {
              "const": "alg"
            },
            "assessment": {
              "const": "asmt"
            },
            "audit": {
              "const": "aud"
            },
            "condition": {
              "const": "cond"
            },
            "document": {
              "const": "doc"
            },
            "event": {
              "const": "evt"
            },
            "experiment": {
              "const": "exp"
            },
            "family": {
              "const": "fam"
            },
            "goal": {
              "const": "goal"
            },
            "meal": {
              "const": "meal"
            },
            "pack": {
              "const": "pack"
            },
            "profileSnapshot": {
              "const": "psnap"
            },
            "provider": {
              "const": "prov"
            },
            "regimen": {
              "const": "reg"
            },
            "sample": {
              "const": "smp"
            },
            "transform": {
              "const": "xfm"
            },
            "variant": {
              "const": "var"
            },
            "vault": {
              "const": "vault"
            }
          }
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allergiesRoot",
        "assessmentLedgerRoot",
        "conditionsRoot",
        "coreDocument",
        "familyRoot",
        "geneticsRoot",
        "goalsRoot",
        "journalRoot",
        "experimentsRoot",
        "profileCurrentDocument",
        "profileRoot",
        "profileSnapshotsRoot",
        "providersRoot",
        "rawAssessmentsRoot",
        "rawRoot",
        "eventsRoot",
        "regimensRoot",
        "samplesRoot",
        "auditRoot",
        "exportsRoot"
      ],
      "properties": {
        "allergiesRoot": {
          "const": "bank/allergies"
        },
        "assessmentLedgerRoot": {
          "const": "ledger/assessments"
        },
        "conditionsRoot": {
          "const": "bank/conditions"
        },
        "coreDocument": {
          "const": "CORE.md"
        },
        "familyRoot": {
          "const": "bank/family"
        },
        "geneticsRoot": {
          "const": "bank/genetics"
        },
        "goalsRoot": {
          "const": "bank/goals"
        },
        "journalRoot": {
          "const": "journal"
        },
        "experimentsRoot": {
          "const": "bank/experiments"
        },
        "profileCurrentDocument": {
          "const": "bank/profile/current.md"
        },
        "profileRoot": {
          "const": "bank/profile"
        },
        "profileSnapshotsRoot": {
          "const": "ledger/profile-snapshots"
        },
        "providersRoot": {
          "const": "bank/providers"
        },
        "rawAssessmentsRoot": {
          "const": "raw/assessments"
        },
        "rawRoot": {
          "const": "raw"
        },
        "eventsRoot": {
          "const": "ledger/events"
        },
        "regimensRoot": {
          "const": "bank/regimens"
        },
        "samplesRoot": {
          "const": "ledger/samples"
        },
        "auditRoot": {
          "const": "audit"
        },
        "exportsRoot": {
          "const": "exports"
        }
      }
    },
    "shards": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assessments",
        "events",
        "profileSnapshots",
        "samples",
        "audit"
      ],
      "properties": {
        "assessments": {
          "const": "ledger/assessments/YYYY/YYYY-MM.jsonl"
        },
        "events": {
          "const": "ledger/events/YYYY/YYYY-MM.jsonl"
        },
        "profileSnapshots": {
          "const": "ledger/profile-snapshots/YYYY/YYYY-MM.jsonl"
        },
        "samples": {
          "const": "ledger/samples/<stream>/YYYY/YYYY-MM.jsonl"
        },
        "audit": {
          "const": "audit/YYYY/YYYY-MM.jsonl"
        }
      }
    }
  }
}
