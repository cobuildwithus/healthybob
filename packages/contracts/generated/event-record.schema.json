    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "id",
        "kind",
        "occurredAt",
        "recordedAt",
        "dayKey",
        "source",
        "title",
        "documentId",
        "documentPath",
        "mimeType"
      ],
      "properties": {
        "schemaVersion": {
          "const": "hb.event.v1"
        },
        "id": {
          "type": "string",
          "pattern": "^evt_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "kind": {
          "const": "document"
        },
        "occurredAt": {
          "type": "string",
          "format": "date-time"
        },
        "recordedAt": {
          "type": "string",
          "format": "date-time"
        },
        "dayKey": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "source": {
          "type": "string",
          "enum": [
            "manual",
            "import",
            "device",
            "derived"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "note": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "uniqueItems": true
        },
        "relatedIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?:aud|doc|evt|exp|meal|pack|prov|smp|xfm|vault)_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "uniqueItems": true
        },
        "rawRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^raw/[A-Za-z0-9._/-]+$"
          },
          "uniqueItems": true
        },
        "documentId": {
          "type": "string",
          "pattern": "^doc_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "documentPath": {
          "type": "string",
          "pattern": "^raw/documents/[A-Za-z0-9._/-]+$"
        },
        "mimeType": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120
        },
        "providerId": {
          "type": "string",
          "pattern": "^prov_[0-9A-HJKMNP-TV-Z]{26}$"
        }
      }
    },
