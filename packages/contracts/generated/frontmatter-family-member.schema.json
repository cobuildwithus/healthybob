{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "@healthybob/contracts/frontmatter-family-member.schema.json",
  "title": "Healthy Bob Family Member Frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "docType",
    "familyMemberId",
    "slug",
    "title",
    "relationship"
  ],
  "properties": {
    "schemaVersion": {
      "const": "hb.frontmatter.family-member.v1"
    },
    "docType": {
      "const": "family_member"
    },
    "familyMemberId": {
      "type": "string",
      "pattern": "^fam_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "relationship": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 160
      },
      "uniqueItems": true
    },
    "deceased": {
      "type": "boolean"
    },
    "note": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "relatedVariantIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^var_[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "uniqueItems": true
    }
  }
}
