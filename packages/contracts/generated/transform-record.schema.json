{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "@healthybob/contracts/transform-record.schema.json",
  "title": "Healthy Bob Transform Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "transformType",
    "status",
    "appliedAt",
    "input",
    "output"
  ],
  "properties": {
    "schemaVersion": {
      "const": "hb.transform.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^xfm_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "transformType": {
      "type": "string",
      "enum": [
        "document_import",
        "meal_add",
        "samples_import_csv",
        "export_pack"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failed"
      ]
    },
    "appliedAt": {
      "type": "string",
      "format": "date-time"
    },
    "errorCode": {
      "type": "string",
      "enum": [
        "HB_CONTRACT_INVALID",
        "HB_ID_INVALID",
        "HB_PATH_INVALID",
        "HB_VAULT_INVALID",
        "HB_EVENT_INVALID",
        "HB_SAMPLE_INVALID",
        "HB_AUDIT_INVALID",
        "HB_TRANSFORM_INVALID",
        "HB_FRONTMATTER_INVALID",
        "HB_ENUM_UNSUPPORTED",
        "HB_SHARD_KEY_INVALID",
        "HB_SCHEMA_ARTIFACT_STALE"
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceKind",
        "rawPaths",
        "sourceLabel"
      ],
      "properties": {
        "sourceKind": {
          "type": "string",
          "enum": [
            "file",
            "csv",
            "manual",
            "derived"
          ]
        },
        "rawPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^raw/[A-Za-z0-9._/-]+$"
          },
          "minItems": 1
        },
        "sourceLabel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eventIds",
        "sampleIds",
        "auditIds",
        "markdownPaths"
      ],
      "properties": {
        "eventIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^evt_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "uniqueItems": true
        },
        "sampleIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^smp_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "uniqueItems": true
        },
        "auditIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^aud_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "uniqueItems": true
        },
        "markdownPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
