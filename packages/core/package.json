{
  "name": "@healthybob/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit --pretty false",
    "test": "pnpm --dir ../.. exec vitest run packages/core/test/core.test.ts packages/core/test/profile.test.ts packages/core/test/health-bank.test.ts packages/core/test/health-history-family.test.ts --no-coverage"
  },
  "dependencies": {
    "@healthybob/contracts": "workspace:*"
  }
}
