{
  "id": "journal-link-event",
  "command": "vault-cli journal link-event <date> --vault <path> --id <evt_*> [--id <evt_*> ...] [--format json|md] [--request-id <id>]",
  "vaultFixture": "fixtures/minimal-vault",
  "inputs": [
    "fixtures/minimal-vault/journal/2026/2026-03-10.md",
    "fixtures/minimal-vault/ledger/events/README.md"
  ],
  "goldenOutput": "fixtures/golden-outputs/journal-ensure",
  "purpose": "Documents linking one or more canonical event ids into a journal day frontmatter collection."
}
