{
  "id": "event-list",
  "command": "vault-cli event list --vault <path> [--kind <kind>] [--from <date>] [--to <date>] [--tag <tag>] [--experiment <slug>] [--limit <n>] [--format json|md] [--request-id <id>]",
  "vaultFixture": "fixtures/minimal-vault",
  "inputs": [
    "fixtures/minimal-vault/ledger/events/README.md",
    "fixtures/minimal-vault/bank/experiments/baseline-observation.md"
  ],
  "goldenOutput": "fixtures/golden-outputs/list",
  "purpose": "Documents generic event listing with kind, date, tag, and experiment filters."
}
