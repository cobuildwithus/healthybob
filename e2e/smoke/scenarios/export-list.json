{
  "id": "export-list",
  "command": "vault-cli export list --vault <path> [--from <date>] [--to <date>] [--experiment <slug>] [--limit <n>] [--format json|md] [--request-id <id>]",
  "vaultFixture": "fixtures/minimal-vault",
  "inputs": [
    "fixtures/minimal-vault/exports/README.md",
    "fixtures/minimal-vault/bank/experiments/baseline-observation.md"
  ],
  "goldenOutput": "fixtures/golden-outputs/export-pack",
  "purpose": "Documents listing stored export packs by date scope and optional experiment filter."
}
